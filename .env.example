# Protek — example environment file
# Copy to .env and fill in. Never commit the real .env.

# ────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────
SECRET_KEY=                       # generated by scripts/setup_admin.py
APP_USERNAME=admin                # overridable via scripts/setup_admin.py --username
APP_PASSWORD_HASH=                # bcrypt hash — generated by scripts/setup_admin.py (never plaintext)
TOTP_SECRET=                      # generated by scripts/setup_admin.py (base32, GAuth-compatible)

# ────────────────────────────────────────────────────────────
# CrowdSec LAPI — local agent on this VPS
# ────────────────────────────────────────────────────────────
CROWDSEC_LAPI_URL=http://127.0.0.1:8080
CROWDSEC_BOUNCER_KEY=             # `sudo cscli bouncers add protek` → paste the printed key

# Optional — enables the /alerts page (richer event context with log lines,
# ASN, scenarios per event). Bouncer keys are read-only on decisions; the
# alerts endpoint requires a separate machine credential.
# Create with: `sudo cscli machines add protek-machine`
# (cscli will print machine_id + password — paste both here.)
CROWDSEC_MACHINE_LOGIN=
CROWDSEC_MACHINE_PASSWORD=

# ────────────────────────────────────────────────────────────
# MikroTik RouterOS API
# ────────────────────────────────────────────────────────────
MT_HOST=                          # IP or hostname of the MikroTik (often reached over WireGuard)
MT_USERNAME=                      # dedicated user with API + write access to /ip/firewall/address-list
MT_PASSWORD=
MT_PORT=8728                      # 8728 = API, 8729 = API-SSL
MT_USE_SSL=false
MT_ADDRESS_LIST=crowdsec          # address-list name Protek will manage

# ────────────────────────────────────────────────────────────
# Reconcile loop
# ────────────────────────────────────────────────────────────
SYNC_INTERVAL_SEC=10              # how often to pull LAPI + reconcile
BATCH_CAP=200                     # max add/remove ops per cycle (excess queued)
DRY_RUN=true                      # leave true for first deploy; flip to false after verification

# ────────────────────────────────────────────────────────────
# Security
# ────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
SESSION_TIMEOUT_MIN=30
IP_WHITELIST=                     # comma-separated; blank = allow all

# ────────────────────────────────────────────────────────────
# Notifications (all optional)
# ────────────────────────────────────────────────────────────
DISCORD_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ────────────────────────────────────────────────────────────
# Geo lookups
# ────────────────────────────────────────────────────────────
GEO_CACHE_TTL_DAYS=7
GEO_PROVIDER=ipapi                # ipapi | ip-api — both free-tier, attribution required

# ────────────────────────────────────────────────────────────
# Observability (Arc 6)
# ────────────────────────────────────────────────────────────
METRICS_TOKEN=                    # bearer token for /metrics. Unset = localhost-only scraping.
SYSLOG_HOST=                      # RFC 5424 syslog forwarder host. Unset = forwarding disabled.
SYSLOG_PORT=514                   # UDP port
SYSLOG_PROTO=udp                  # udp | tcp

# ────────────────────────────────────────────────────────────
# Intelligence v2 (Arc 10) — all optional; missing keys = provider silently skipped.
# ────────────────────────────────────────────────────────────
ABUSEIPDB_API_KEY=                # https://www.abuseipdb.com/account/api  (1000/day free)
PROXYCHECK_API_KEY=               # https://proxycheck.io/  (1000/day free, VPN/proxy detection)
# OTX, Spamhaus, Tor exit list — no key needed, just refresh daily.

# ────────────────────────────────────────────────────────────
# Suite integrations (Arc 8 / phases 48-49)
# ────────────────────────────────────────────────────────────
ATOM_URL=                         # base URL of your atom box for cross-app links on /attackers
OTHONI_URL=                       # base URL of your othoni box for cross-app links
