# Litestream config — copy to /etc/litestream.yml and edit.
# Streams /var/www/Protek/protek.db's WAL to your S3-compatible bucket
# in near-real time (RPO < 60s under steady state).
#
# Install Litestream first:
#   curl -L https://github.com/benbjohnson/litestream/releases/latest/download/litestream-linux-amd64.tar.gz \
#     | tar -xz -C /usr/local/bin litestream
#   # arm64: replace linux-amd64 with linux-arm64
#
# Then drop the systemd unit alongside this config:
#   cp /var/www/Protek/docs/litestream/protek-litestream.service.example \
#      /etc/systemd/system/litestream.service
#   systemctl daemon-reload
#   systemctl enable --now litestream
#
# Restore (full DB) from B2:
#   systemctl stop protek litestream
#   litestream restore -o /var/www/Protek/protek.db /var/www/Protek/protek.db
#   systemctl start litestream protek

dbs:
  - path: /var/www/Protek/protek.db
    # Generation-aware retention: keeps the last 72h of incremental WAL frames
    # so any point-in-time recovery within that window is possible.
    replicas:
      - name: b2
        type: s3
        # Match the values in your Protek .env (BACKUP_S3_*)
        endpoint: https://s3.us-west-002.backblazeb2.com
        region: us-west-002
        bucket: YOUR_BUCKET_NAME
        path: protek/litestream         # keep separate from /daily/ /monthly/ used by backup.py
        access-key-id:     YOUR_B2_KEY_ID
        secret-access-key: YOUR_B2_APP_KEY

        # Snapshot every hour, retain last 7 days of snapshots + WAL
        snapshot-interval: 1h
        retention: 168h               # 7 days
        retention-check-interval: 1h
        sync-interval: 1s             # how often litestream uploads WAL frames
